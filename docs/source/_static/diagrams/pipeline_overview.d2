# Homepage overview
direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 1
  }
}

style: {
  fill: "#ffffff"
  stroke: "#37474f"
  stroke-width: 2
  border-radius: 8
  font-color: "#263238"
  font-size: 14
  shadow: true
}

